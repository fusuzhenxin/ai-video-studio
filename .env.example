# ===== AI 大模型 API 配置 =====
# 只需配置您选择使用的模型对应的 API Key，无需全部填写

# ========== 1. OpenAI (文本分析 + DALL-E 图片生成) ==========
OPENAI_API_KEY=sk-2292bf9e35ee4f8981510d1be6839687
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3

# ========== 2. 通义千问 / 通义万相 (阿里云 DashScope) ==========
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-2292bf9e35ee4f8981510d1be6839687
QIANWEN_MODEL=qwen-max
WANXIANG_IMAGE_MODEL=qwen-image-2.0

# ========== 3. 豆包 / 即梦 (字节跳动火山引擎) ==========
# 豆包文本模型 - 获取地址: https://console.volcengine.com/ark
VOLCENGINE_API_KEY=xxxxxxxxxxxxxxxxxxxx
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-256k
# 即梦图片 - 获取地址: https://jimeng.jianying.com/
JIMENG_API_KEY=xxxxxxxxxxxxxxxxxxxx
JIMENG_BASE_URL=https://jimeng.jianying.com/mweb/v1
JIMENG_IMAGE_MODEL=jimeng-2.1
# 豆包 Seedream 文生图 (使用同一个 VOLCENGINE_API_KEY)
DOUBAO_IMAGE_MODEL=doubao-seedream-4-5-251128
# 豆包 Seedance 图生视频 (使用同一个 VOLCENGINE_API_KEY)
DOUBAO_VIDEO_MODEL=doubao-seedance-1-5-pro-251215

# ========== 4. Replicate (视频生成 - Stable Video Diffusion) ==========
# 获取地址: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxx
REPLICATE_VIDEO_MODEL=stability-ai/stable-video-diffusion:3f0457e4619daac51203dedb472816fd4af51f3149fa7a9e0b5ffcf1b8172438
